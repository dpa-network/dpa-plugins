{
  "description": "Context Monitor — injects context window usage into every turn",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/read-context.mjs",
            "timeout": 2000
          }
        ]
      }
    ]
  }
}
